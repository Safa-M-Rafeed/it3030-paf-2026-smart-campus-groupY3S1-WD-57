    {
      "name": "Resource CRUD (Public)",
      "item": [
        {
          "name": "Create Resource",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Hall {{$timestamp}}\",\n  \"type\": \"LECTURE_HALL\",\n  \"capacity\": 120,\n  \"location\": \"Block A\",\n  \"description\": \"Auto-created from Postman collection\",\n  \"availabilityWindows\": [\"Mon-Fri 08:00-16:00\"],\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/resources",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "resources"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Resource id returned', function () {",
                  "  pm.expect(json.data).to.have.property('id');",
                  "});",
                  "pm.environment.set('resourceId', json.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Resource By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "resources",
                "{{resourceId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Correct resource returned', function () {",
                  "  pm.expect(json.data.id).to.eql(pm.environment.get('resourceId'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Resource Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"OUT_OF_SERVICE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/resources/{{resourceId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "resources",
                "{{resourceId}}",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Status changed', function () {",
                  "  pm.expect(json.data.status).to.eql('OUT_OF_SERVICE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Resource",
          "request": {
            "method": "PUT",
