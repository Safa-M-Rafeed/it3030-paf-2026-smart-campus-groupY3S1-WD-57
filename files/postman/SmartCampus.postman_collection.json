            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Hall Updated {{$timestamp}}\",\n  \"type\": \"LECTURE_HALL\",\n  \"capacity\": 150,\n  \"location\": \"Block B\",\n  \"description\": \"Updated by Postman collection\",\n  \"availabilityWindows\": [\"Mon-Fri 09:00-17:00\"],\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/resources/{{resourceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "resources",
                "{{resourceId}}"
              ]
