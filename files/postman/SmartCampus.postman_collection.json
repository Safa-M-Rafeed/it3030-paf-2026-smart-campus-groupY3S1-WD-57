      "item": [
        {
          "name": "Root Redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Root endpoint is reachable', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 301, 302, 307, 308]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
