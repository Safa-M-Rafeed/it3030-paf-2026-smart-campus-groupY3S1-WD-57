          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Capacity updated', function () {",
                  "  pm.expect(json.data.capacity).to.eql(150);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
